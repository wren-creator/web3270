{
  "name": "TSO ISPF Login",
  "description": "Log in to TSO and navigate to ISPF Primary Menu",
  "created": "2024-01-01T00:00:00.000Z",
  "steps": [
    { "op": "comment", "text": "Wait for TSO logon screen" },
    { "op": "wait",    "condition": "text", "row": 2, "col": 25, "text": "TSO/E LOGON", "timeoutMs": 10000 },

    { "op": "comment", "text": "Enter userid" },
    { "op": "type",    "row": 6, "col": 14, "text": "JSMITH" },

    { "op": "comment", "text": "Tab to password field and enter it" },
    { "op": "type",    "row": 7, "col": 14, "text": "mypassword" },

    { "op": "comment", "text": "Submit logon" },
    { "op": "aid",     "aid": "ENTER", "fields": [] },
    { "op": "wait",    "condition": "unlock" },

    { "op": "comment", "text": "Wait for ISPF primary menu" },
    { "op": "wait",    "condition": "text", "row": 0, "col": 24, "text": "ISPF Primary Option Menu", "timeoutMs": 15000 }
  ]
}
