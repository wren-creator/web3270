# WebTerm/3270 Bridge — environment configuration
# Copy this to .env and edit before running.
# All values here override the defaults in config.js.

# ── Bridge listener ────────────────────────────────────────────────
BRIDGE_PORT=8080
LOG_LEVEL=info

# ── TLS / certificate settings ─────────────────────────────────────
# Set to false only if your mainframe uses a self-signed cert
BRIDGE_VERIFY_TLS=true

# ── LPAR profiles ──────────────────────────────────────────────────
# Each LPAR has its own host AND port — they are independent.

PROD01_HOST=mainframe.corp.com
PROD01_PORT=992
PROD01_TLS=true
PROD01_LU=

DEV02_HOST=dev-mf.corp.com
DEV02_PORT=23
DEV02_TLS=false

QA01_HOST=qa-mf.corp.com
QA01_PORT=23
QA01_TLS=false

# ── Terminal defaults ──────────────────────────────────────────────
# 3278-2=80x24  3278-3=80x32  3278-4=80x43  3278-5=132x27
DEFAULT_MODEL=3278-2

# 37=US English  500=International  285=UK  273=Germany
DEFAULT_CODEPAGE=37
