FROM node:20-alpine

WORKDIR /app

# Only copy what the mock z/VM daemon needs — no bridge deps required
COPY mock-lpar/mock-zvm.js ./mock-lpar/mock-zvm.js

RUN addgroup -S mockzvm && adduser -S mockzvm -G mockzvm
USER mockzvm

EXPOSE 3271

ENV MOCK_ZVM_PORT=3271 \
    MOCK_ZVM_SYSID=ZVMPROD \
    MOCK_ZVM_VMID=ZVMSYS1 \
    MOCK_ZVM_LU=ZVMLU01 \
    LOG_LEVEL=info

CMD ["node", "mock-lpar/mock-zvm.js"]
