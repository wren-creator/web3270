{
  "name": "SDSF Job Query",
  "description": "Open SDSF and filter to a specific job name",
  "created": "2024-01-01T00:00:00.000Z",
  "steps": [
    { "op": "comment", "text": "Must be on ISPF Primary Menu" },
    { "op": "wait",    "condition": "text", "row": 0, "col": 24, "text": "ISPF Primary Option Menu" },

    { "op": "comment", "text": "Type SDSF command" },
    { "op": "type",    "row": 2, "col": 13, "text": "M" },
    { "op": "aid",     "aid": "ENTER" },
    { "op": "wait",    "condition": "unlock" },

    { "op": "comment", "text": "Look for SDSF menu or direct ST panel" },
    { "op": "wait",    "condition": "screen", "timeoutMs": 8000 },

    { "op": "comment", "text": "Type ST (status) on the SDSF command line" },
    { "op": "type",    "row": 1, "col": 16, "text": "ST" },
    { "op": "aid",     "aid": "ENTER" },
    { "op": "wait",    "condition": "unlock" },

    { "op": "comment", "text": "Filter by job prefix" },
    { "op": "type",    "row": 1, "col": 16, "text": "PREFIX MYJOB*" },
    { "op": "aid",     "aid": "ENTER" },
    { "op": "wait",    "condition": "unlock" }
  ]
}
